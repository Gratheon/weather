{
  "name": "weather",
  "version": "1.0.0",
  "description": "Weather management",
  "main": "server.js",
  "dependencies": {
    "@apollo/server": "^5.0.0",
    "@apollo/subgraph": "^2.11.2",
    "@as-integrations/fastify": "^3.1.0",
    "@databases/mysql": "7.0.0",
    "@gratheon/log-lib": "^2.2.7",
    "fast-safe-stringify": "2.1.1",
    "fastify": "^5.7.4",
    "got": "^11.8.6",
    "graphql": "^16.11.0",
    "jwt-encode": "1.0.1",
    "mysql2": "3.16.2",
    "node-fetch": "^2.7.0",
    "sha1": "1.1.1",
    "xml2js": "^0.6.2"
  },
  "scripts": {
    "test": "node test/integration.test.js",
    "test:ci": "pnpm run build && pnpm run test:wait-and-run",
    "test:wait-and-run": "node -e \"const http=require('http');const check=()=>http.get('http://localhost:8070',()=>{console.log('Server ready');process.exit(0)}).on('error',()=>setTimeout(check,1000));check()\" && pnpm test",
    "build": "tsc -p src/config/tsconfig.json",
    "prestart": "sh -c 'if [ ! -f /app/app/weather.js ]; then echo \"weather.js missing, running build\"; pnpm run build; fi'",
    "dev": "tsx watch src/weather.ts",
    "dev-in-docker": "tsx watch src/weather.ts",
    "start": "ENV_ID=prod node /app/app/weather.js",
    "start:local": "ENV_ID=local node /app/app/weather.js"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/gratheon/weather.git"
  },
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=25.0.0"
  },
  "bugs": {
    "url": "https://github.com/gratheon/weather/issues"
  },
  "homepage": "https://github.com/gratheon/weather#readme",
  "packageManager": "pnpm@10.29.2",
  "overrides": {
    "cookie": "^0.7.2"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tsx": "^4.19.2",
    "typescript": "5.2.2"
  }
}
